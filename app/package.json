{
  "name": "cadtab-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:wasm": "wasm-pack build ../crates/cadtab-wasm --target web --out-dir ../../app/src/wasm-gen",
    "build": "npm run build:wasm && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@tauri-apps/api": "^2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/vite-plugin-svelte": "^5",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.0",
    "@tsconfig/svelte": "^5",
    "eslint": "^9.39.4",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5",
    "svelte-check": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.61.1",
    "vite": "^6",
    "vitest": "^3.2.6"
  }
}
